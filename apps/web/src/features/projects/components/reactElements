<form>
  {/* 1. Text input */}
  <input
    type="text"
    placeholder="Enter project name"
  />

  {/* 2. Search input */}
  <input
    type="search"
    placeholder="Search projects..."
  />

  {/* 3. Textarea */}
  <textarea
    placeholder="Describe the project..."
  />

  {/* 4. Select dropdown */}
  <select>
    <option value="all">All statuses</option>
    <option value="active">Active</option>
    <option value="paused">Paused</option>
    <option value="completed">Completed</option>
  </select>

  {/* 5. Radio buttons */}
  <label>
    <input type="radio" name="priority" value="low" />
    Low
  </label>

  <label>
    <input type="radio" name="priority" value="medium" />
    Medium
  </label>

  <label>
    <input type="radio" name="priority" value="high" />
    High
  </label>

  {/* 6. Checkbox */}
  <label>
    <input type="checkbox" />
    Featured project
  </label>

  {/* 7. Button */}
  <button type="button">
    Click me
  </button>

  {/* 8. Date input */}
  <input type="date" />

  {/* 9. Number input */}
  <input
    type="number"
    min={0}
    step={100}
    placeholder="Budget"
  />

  {/* 10. File input */}
  <input
    type="file"
    accept="image/*,.pdf"
  />
</form>

<>
  {/* 1. Email input */}
  <input
    type="email"
    placeholder="Enter email"
  />

  {/* 2. Password input */}
  <input
    type="password"
    placeholder="Enter password"
  />

  {/* 3. Telephone input */}
  <input
    type="tel"
    placeholder="Enter phone number"
  />

  {/* 4. URL input */}
  <input
    type="url"
    placeholder="Enter website URL"
  />

  {/* 5. Range slider */}
  <input
    type="range"
    min={0}
    max={100}
    step={5}
  />

  {/* 6. Color picker */}
  <input type="color" />

  {/* 7. Time input */}
  <input type="time" />

  {/* 8. Date and time input */}
  <input type="datetime-local" />

  {/* 9. Month input */}
  <input type="month" />

  {/* 10. Reset button */}
  <button type="reset">
    Reset
  </button>
</>